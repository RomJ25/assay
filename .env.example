# Universe: sp500, us_all, tase, tase_all, us_all+tase_all
ASSAY_UNIVERSE=sp500

# Number of top results to display
ASSAY_TOP_N=30

# Mode: server (API + scheduler + UI) or scan (one-off screen, then exit)
ASSAY_MODE=server

# Include financial sector stocks (banks, insurance, REITs)
# ASSAY_INCLUDE_FINANCIALS=1

# Use sector-relative scoring (70% absolute + 30% within-sector)
# ASSAY_SECTOR_RELATIVE=1

# Daily auto-refresh time (24h format, container timezone)
ASSAY_SCHEDULE_HOUR=06
ASSAY_SCHEDULE_MIN=00

# Additional CORS origin for production (e.g., https://assay.example.com)
# ASSAY_CORS_ORIGIN=

# Data paths (defaults work for both local and Docker)
# ASSAY_RESULTS=/app/data/results
# ASSAY_CACHE_DB=/app/data/cache.db

# Fetching tuning (advanced)
# ASSAY_BATCH_SIZE=120
# ASSAY_BATCH_DELAY=3
